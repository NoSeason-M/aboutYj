{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aboutYj",
  "version": "0.2.1",
  "identifier": "com.aboutYj.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "aboutYj",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/NoSeason-M/aboutYj/releases/download/latest/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0NUFGQkQ3OEZDM0M5NkQKUldSdHljT1AxL3RhVkRQejFzbmJjbGV6azd6VFBQUUFvMERJOWZGeEdMcmw4QmdPZlhrTTZjREkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}