# 1. 依赖包（绝对不传，几万个文件，超大）
node_modules/
.pnpm-store/

# 2. 项目打包产物（本地生成，不用传）
dist/
dist-ssr/
*.local

# 3. Tauri 编译文件（巨⼤，自动生成，必须排除）
src-tauri/target/
src-tauri/gen/
src-tauri/.cargo/
src-tauri/Cargo.lock

# 4. 环境变量 / 私密配置（不能传！）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 5. 编辑器 / 系统垃圾文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# 6. 日志 / 缓存
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 7. 其他临时文件
*.log
tmp/
temp/
